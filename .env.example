# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/ravi_zoho

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# Zoho API Configuration
ZOHO_CLIENT_ID=your_zoho_client_id
ZOHO_CLIENT_SECRET=your_zoho_client_secret
ZOHO_REDIRECT_URI=http://localhost:5000/api/zoho/callback
ZOHO_ORG_ID=your_zoho_org_id
ZOHO_REFRESH_TOKEN=your_zoho_refresh_token

# Zoho API Base URLs
ZOHO_PEOPLE_BASE_URL=https://people.zoho.com/people/api
ZOHO_PAYROLL_BASE_URL=https://payroll.zoho.com/api/v1

# Frontend URLs
WEBSITE_URL=http://localhost:3000
MOBILE_DEEP_LINK=ravizoho://
